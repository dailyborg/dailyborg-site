{
    "name": "dailyborg-site-feeder",
    "main": "src/workers/feeder.ts",
    "compatibility_date": "2026-03-05",
    "triggers": {
        "crons": [
            "0 * * * *"
        ]
    },
    "queues": {
        "producers": [
            {
                "binding": "ENRICHMENT_QUEUE",
                "queue": "enrichment-queue"
            },
            {
                "binding": "PROCESSING_QUEUE",
                "queue": "processing-queue"
            }
        ],
        "consumers": [
            {
                "queue": "enrichment-queue",
                "max_batch_size": 1,
                "max_retries": 1
            },
            {
                "queue": "processing-queue",
                "max_batch_size": 1,
                "max_retries": 1
            }
        ]
    },
    "d1_databases": [
        {
            "binding": "DB",
            "database_name": "dailyborg-db",
            "database_id": "c412efcd-54d8-47a6-9ca5-8522417992c3",
            "migrations_dir": "src/migrations"
        }
    ],
    "vectorize": [
        {
            "binding": "VECTORIZE",
            "index_name": "dailyborg-claims"
        }
    ],
    "ai": {
        "binding": "AI"
    }
}