{
    "name": "dailyborg-feeder",
    "main": "src/index.ts",
    "compatibility_date": "2026-03-05",
    "compatibility_flags": [
        "nodejs_compat"
    ],
    "triggers": {
        "crons": [
            "0 * * * *"
        ]
    },
    "queues": {
        "producers": [
            {
                "binding": "ENRICHMENT_QUEUE",
                "queue": "enrichment-queue"
            },
            {
                "binding": "PROCESSING_QUEUE",
                "queue": "processing-queue"
            }
        ],
        "consumers": [
            {
                "queue": "enrichment-queue",
                "max_batch_size": 1,
                "max_retries": 1
            },
            {
                "queue": "processing-queue",
                "max_batch_size": 1,
                "max_retries": 1
            }
        ]
    },
    "d1_databases": [
        {
            "binding": "DB",
            "database_name": "dailyborg-prod-db",
            "database_id": "7d5cfb30-7de4-44cc-8294-2817cb5b4b5c",
            "migrations_dir": "../src/migrations"
        }
    ],
    "vectorize": [
        {
            "binding": "VECTORIZE",
            "index_name": "dailyborg-claims"
        }
    ],
    "ai": {
        "binding": "AI"
    }
}