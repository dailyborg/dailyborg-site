{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "dailyborg",
	"compatibility_date": "2026-03-05",
	"compatibility_flags": [
		"nodejs_compat"
	],
	"main": ".vercel/output/static/_worker.js/index.js",
	"assets": {
		"directory": ".vercel/output/static",
		"binding": "ASSETS"
	},
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "dailyborg-prod-db",
			"database_id": "7d5cfb30-7de4-44cc-8294-2817cb5b4b5c"
		}
	]
}
